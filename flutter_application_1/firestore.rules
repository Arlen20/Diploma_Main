rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // All per-user subcollections (meals, plans, water, weights, …).
      // Rules do not cascade, so a recursive match keeps every current and
      // future subcollection owned by the user accessible to that user only.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
